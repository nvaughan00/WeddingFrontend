@using WeddingFrontend.Models

<div class="entree-card @(!Enabled ? "entree-disabled" : "")">
    <p class="entree-guest-name">- Select An Entree For -</p>
    <p class="entree-guest-name">@Guest.Name</p>
    <div class="entree-options">
        @foreach (var option in entrees)
        {
            <div class="entree-option @(SelectedEntree == option ? "selected" : "") @(justSelectedEntree == option ? "entree-just-selected-active" : "") @(!Enabled ? "entree-option-disabled" : "")"
                 @onclick="() => { if (Enabled) SelectEntree(option); }">
                <div class="entree-image-wrap">
                    <img class="entree-image" src="images/@(option.ToLower()).jpg" alt="@option" />
                </div>
                <p class="entree-label">@option</p>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(SelectedEntree) && Enabled)
    {
        <div class="submit-wrap">
            <button class="submit-btn" @onclick="Submit">Confirm @Guest.Name's Entree</button>
        </div>
    }

    @if (showSaved)
    {
        <p class="entree-saved-label">✓ Saved</p>
    }
</div>

@code {
    [Parameter] public Guest Guest { get; set; } = new();
    [Parameter] public EventCallback<(Guest, string)> OnEntreeSelected { get; set; }
    [Parameter] public bool Enabled { get; set; }

    private string SelectedEntree { get; set; } = string.Empty;
    private string? justSelectedEntree = null;
    private List<string> entrees = new() { "Steak", "Salmon", "Pasta" };
    private bool showSaved = false;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Guest.Entree))
            SelectedEntree = Guest.Entree;
    }

    private void SelectEntree(string entree)
    {
        if (!Enabled) return;
        SelectedEntree = entree;
        justSelectedEntree = entree;
    }

    private async Task Submit()
    {
        if (string.IsNullOrEmpty(SelectedEntree)) return;
        showSaved = true;
        justSelectedEntree = null;
        await OnEntreeSelected.InvokeAsync((Guest, SelectedEntree));

        await Task.Delay(2000);
        showSaved = false;
        StateHasChanged();
    }
}
<div class="rsvp-container">
    <h1 class="rsvp-title">RSVP</h1>
    <p class="rsvp-subtitle">Please select your household to begin.</p>

    <div class="dropdown-wrap" style="@(isOpen ? "margin-bottom: 30vh" : "margin-bottom: 0")">
        @if (HouseholdNames.Any())
        {
            <div class="custom-select @(isOpen ? "open" : "")">
                <div class="custom-select-display" @onclick="ToggleOpen" @onclick:stopPropagation>
                    <span class="@(selectedName == null ? "placeholder" : "")">
                        @(selectedName ?? "— Select your family —")
                    </span>
                </div>
                @if (isOpen)
                {
                    <ul class="custom-options">
                        @foreach (var name in HouseholdNames)
                        {
                            <li class="custom-option @(name == selectedName ? "selected" : "")"
                                @onclick:stopPropagation
                                @onclick="() => SelectName(name)">
                                @name
                            </li>
                        }
                    </ul>
                }
            </div>
        }
        else
        {
            <p class="rsvp-subtitle">Loading...</p>
        }
    </div>
</div>

@code {
    [Parameter] public List<string> HouseholdNames { get; set; } = new();
    [Parameter] public EventCallback<string> FamilyNameSelected { get; set; }
    [Parameter] public bool Enabled { get; set; }

    private string? selectedName = null;
    private bool isOpen = false;

    private void ToggleOpen() 
    {
        if (!Enabled) return;
        isOpen = !isOpen;
    }

    private async Task SelectName(string name)
    {
        selectedName = name;
        isOpen = false;
        await FamilyNameSelected.InvokeAsync(name);
    }
}
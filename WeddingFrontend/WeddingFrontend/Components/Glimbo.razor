@implements IDisposable
@using System.Linq

<div class="glimbo-wrap @AnchorClass @_state" aria-hidden="true">
    <img src="@ImageSrc" class="glimbo-img" alt="Glimbo" />
</div>

@code {
    public enum GlimboPeekAnchor
    {
        Left,
        Right,
        Top,
        Bottom,
        TopLeft,
        TopRight,
        BottomLeft,
        BottomRight
    }

    [Parameter] public string ImageSrc { get; set; } = "/images/glimbo.png";
    [Parameter] public int CheckIntervalMs { get; set; } = 8000;
    [Parameter] public double AppearChance { get; set; } = 0.95;
    [Parameter] public int PeekDurationMs { get; set; } = 4000;
    [Parameter] public IReadOnlyCollection<GlimboPeekAnchor>? AllowedAnchors { get; set; }

    private static readonly GlimboPeekAnchor[] DefaultAnchors =
        Enum.GetValues<GlimboPeekAnchor>();

    private readonly Random _rng = new();
    private CancellationTokenSource? _cts;
    private string _state = "idle";
    private GlimboPeekAnchor _anchor = GlimboPeekAnchor.Right;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = RunLoopAsync(_cts.Token);
    }

    private async Task RunLoopAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(Math.Max(0, CheckIntervalMs), token);

                if (token.IsCancellationRequested || _state != "idle")
                {
                    continue;
                }

                if (_rng.NextDouble() >= AppearChance)
                {
                    continue;
                }

                _anchor = PickAnchor();
                _state = "peeking";
                await InvokeAsync(StateHasChanged);

                await Task.Delay(Math.Max(0, PeekDurationMs), token);

                _state = "retreating";
                await InvokeAsync(StateHasChanged);

                await Task.Delay(650, token);

                _state = "idle";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private GlimboPeekAnchor PickAnchor()
    {
        var anchors = (AllowedAnchors is { Count: > 0 } ? AllowedAnchors : DefaultAnchors).ToArray();
        return anchors[_rng.Next(anchors.Length)];
    }

    private string AnchorClass => _anchor switch
    {
        GlimboPeekAnchor.Left => "anchor-left",
        GlimboPeekAnchor.Right => "anchor-right",
        GlimboPeekAnchor.Top => "anchor-top",
        GlimboPeekAnchor.Bottom => "anchor-bottom",
        GlimboPeekAnchor.TopLeft => "anchor-top-left",
        GlimboPeekAnchor.TopRight => "anchor-top-right",
        GlimboPeekAnchor.BottomLeft => "anchor-bottom-left",
        GlimboPeekAnchor.BottomRight => "anchor-bottom-right",
        _ => "anchor-right"
    };

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}

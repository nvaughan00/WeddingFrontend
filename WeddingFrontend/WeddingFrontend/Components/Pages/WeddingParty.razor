@page "/weddingparty"

<div class="wp-page">
    <h1 class="wp-title">Wedding Party</h1>
    <p class="wp-subtitle">We're gonna give head to everyone mentioned here.</p>

    <div class="wp-columns">
        <div class="wp-column">
            <h2 class="wp-column-title">Groomsmen</h2>
            <div class="wp-list">
                @foreach (var person in groomsmen)
                {
                    <div class="wp-card" @onclick="() => OnCardClick(person)">
                        <div class="wp-img-wrap">
                            <img src="@person.ImagePath" alt="@person.Name" class="wp-img" />
                        </div>
                        <div class="wp-info">
                            <p class="wp-name">@person.Name</p>
                            <p class="wp-role">@person.Role</p>
                            <p class="wp-bio">@person.Bio</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="wp-column">
            <h2 class="wp-column-title">Bridesmaids</h2>
            <div class="wp-list">
                @foreach (var person in bridesmaids)
                {
                    <div class="wp-card" @onclick="() => OnCardClick(person)">
                        <div class="wp-img-wrap">
                            <img src="@person.ImagePath" alt="@person.Name" class="wp-img" />
                        </div>
                        <div class="wp-info">
                            <p class="wp-name">@person.Name</p>
                            <p class="wp-role">@person.Role</p>
                            <p class="wp-bio">@person.Bio</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="wp-mentions-section">
        <h2 class="wp-column-title">Special Mentions</h2>
        <div class="wp-mentions-list">
            @foreach (var mention in specialMentions)
            {
                <div class="wp-mention">
                    <div class="wp-mention-img-wrap">
                        <img src="@mention.ImagePath" alt="@mention.Name" class="wp-mention-img" />
                    </div>
                    <p class="wp-mention-name">@mention.Name</p>
                    <p class="wp-mention-note">@mention.Note</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private void OnCardClick(WeddingPartyMember person)
    {
        Console.WriteLine($"Clicked: {person.Name}");
    }

    private List<WeddingPartyMember> groomsmen = new()
    {

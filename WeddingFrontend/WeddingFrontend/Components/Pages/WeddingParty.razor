        new("Aidan Vaughan", "Groomsman", "Thinks he's stronger than David. They're going to arm wrestle at the wedding.", "images/test.jpg"),
        new("David 'The Drink' Breese", "Groomsman", "Can definitely hit a front lever. Ask him about it.", "images/test.jpg"),

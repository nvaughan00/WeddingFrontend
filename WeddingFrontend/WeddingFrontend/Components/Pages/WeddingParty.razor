@page "/weddingparty"
@using WeddingFrontend.Services

@inject GlimboService GlimboService

<div class="wp-page">
    <h1 class="wp-title">Wedding Party</h1>
    <p class="wp-subtitle">We're gonna give head to everyone mentioned here.</p>

    <div class="wp-columns">
        <div class="wp-column">
            <h2 class="wp-column-title">Groomsmen</h2>
            <div class="wp-list">
                @foreach (var person in groomsmen)
                {
                    <div class="wp-card">
                        <div class="wp-img-wrap">
                            <img src="@person.ImagePath" alt="@person.Name" class="wp-img" />
                        </div>
                        <div class="wp-info">
                            <p class="wp-name">@person.Name</p>
                            <p class="wp-role">@person.Role</p>
                            <p class="wp-bio">@person.Bio</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="wp-column">
            <h2 class="wp-column-title">Bridesmaids</h2>
            <div class="wp-list">
                @foreach (var person in bridesmaids)
                {
                    <div class="wp-card">
                        <div class="wp-img-wrap">
                            <img src="@person.ImagePath" alt="@person.Name" class="wp-img" />
                        </div>
                        <div class="wp-info">
                            <p class="wp-name">@person.Name</p>
                            <p class="wp-role">@person.Role</p>
                            <p class="wp-bio">@person.Bio</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="wp-mentions-section">
        <h2 class="wp-column-title">Special Mentions</h2>
        <div class="wp-mentions-list">
            @foreach (var mention in specialMentions)
            {
                <div class="wp-mention" @onclick="() => OnCardClick(mention)">
                    <div class="wp-mention-img-wrap">
                        <img src="@mention.ImagePath" alt="@mention.Name" class="wp-mention-img" />
                    </div>
                    <p class="wp-mention-name">@mention.Name</p>
                    <p class="wp-mention-note">@mention.Note</p>
                </div>
            }
        </div>
    </div>
</div>

@code {


    private async Task OnCardClick(SpecialMention person)
    {
        if (person.Name == "Glimbo")
        {
            GlimboService.Trigger(true);
        }
    }

    private List<WeddingPartyMember> groomsmen = new()
    {
        new("Steven 'The Hog' McCormick", "Best Man", "Once lost in the championship round of a national Muay Thai torunament.", "images/steve.png"),
        new("Ben Vaughan", "Groomsman", "Left the material plane to become a psychic tree. He's just back for vacation", "images/test.jpg"),
        new("Aidan Vaughan", "Groomsman", "Thinks he's stronger than David. They're going to arm wrestle at the wedding.", "images/aidan.png"),
        new("David 'The Drink' Breese", "Groomsman", "Can definitely hit a front lever. Ask him about it.", "images/david.png"),
        new("Max Frost", "Groomsman", "Better known for his hit poem, The Road Taken", "images/test.jpg"),
        new("Parker Day", "Groomsman", "Once drove through a mid-construction road, just because he could.", "images/parker.png"),
    };

    private List<WeddingPartyMember> bridesmaids = new()
    {
        new("Emily Ganson", "Matron of Honor", "Can talk with her mouth closed. Please ask her to demonstrate.", "images/test.jpg"),
        new("Jordan Tomlin", "Bridesmaid", "Whitney & Jordan have a lot of things in common, but most importantly, they both gave birth to the cutest babies on Earth.", "images/jordan.png"),
        new("Hannah Wilder", "Bridesmaid", "placeholder", "images/hannah.png"),
        new("Maddie Dusselier", "Bridesmaid", "Saw each Fifty Shades of Grey movies in theatres -- on Valentines Day -- with Whitney.", "images/maddie.png"),
        new("Ashley Cave", "Bridesmaid", "Pretty sure she can still lick her elbow.", "images/ashley.png"),
        new("Kelsey Edwards", "Bridesmaid", "placeholder", "images/test.jpg"),
    };

    private List<SpecialMention> specialMentions = new()
    {
        new("John & Susan Edwards", "For being the best parents.", "images/test.jpg"),
        new("Kevin & Anne Marie Vaughan", "For also being the best parents.", "images/test.jpg"),
        new("Meepo", "For his endless nights of yowling & waking up the baby.", "images/test.jpg"),
        new("Glimbo", "Protector of us all. King to many.", "images/glimbo2.png")
    };

    private record WeddingPartyMember(string Name, string Role, string Bio, string ImagePath);
    private record SpecialMention(string Name, string Note, string ImagePath);
}

@using WeddingFrontend.Context
@using WeddingFrontend.Models
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="battle-page">
    <div class="battle-container">
        <div class="battle-header">
            <h3>Nick vs. Whitney</h3>
        </div>
        <div class="battle-labels">
            <span class="battle-label left-label">@LeftLabel</span>
            <span class="battle-score">@Score.NickScore — @Score.WhitneyScore</span>
            <span class="battle-label right-label">@RightLabel</span>
        </div>

        <div class="battle-bar-track">
            <div class="battle-bar-left" style="width: @(LeftPercent)%">
                <span class="battle-bar-pct">@LeftPercent%</span>
            </div>
            <div class="battle-divider"></div>
            <div class="battle-bar-right" style="width: @(RightPercent)%">
                <span class="battle-bar-pct">@RightPercent%</span>
            </div>
        </div>

        <div class="battle-buttons">
            <button class="battle-btn left-btn" @onclick="IncrementLeft">
                + @LeftLabel
            </button>
            <button class="battle-btn right-btn" @onclick="IncrementRight">
                + @RightLabel
            </button>
        </div>
        <div class="battle-title">
            Our Story
        </div>
        <div class="battle-subtitle">
            After a 9 hour first date, which of course included coffee & various shark movies, Nick & Whitney knew something was there. Over the next few months, they became inseperable & insufferable, going everywhere & doing everything together.
            In early November, Nick slipped on a banana peel. This led to the formation of their most cherished creation - Eloise. Now, they're on a quest to unify the family name, bringing peace and prosperity to their estate forevermore.
        </div>
    </div>
</div>

@code {
    [Parameter] public string LeftLabel { get; set; } = "Nick";
    [Parameter] public string RightLabel { get; set; } = "Whitney";

    private Score Score { get; set; } = new Score();

    private int Total => Score.NickScore + Score.WhitneyScore;
    private int LeftPercent => (int)Math.Round((double)Score.NickScore / Total * 100);
    private int RightPercent => 100 - LeftPercent;

    private AppDbContext DbContext { get; set; }

    private async Task IncrementLeft()
    {
        Score.NickScore++;
        var score = DbContext.Score.First();
        score.NickScore = Score.NickScore;

        DbContext?.Score.Update(score);
        await DbContext.SaveChangesAsync();
    }

    private async Task IncrementRight()
    {
        Score.WhitneyScore++;
        var score = DbContext.Score.First();
        score.WhitneyScore = Score.WhitneyScore;

        DbContext?.Score.Update(score);
        await DbContext.SaveChangesAsync();
    }


    protected override async Task OnInitializedAsync()
    {
        DbContext = DbFactory.CreateDbContext();

        if(DbContext.Score.Count() == 0)
        {
            DbContext.Score.Add(new Score());
            await DbContext.SaveChangesAsync();
        }

        Score = DbContext.Score.First();
    }
}

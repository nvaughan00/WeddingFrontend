<div class="battle-container">
    <div class="battle-header">
        <h3>Nick vs. Whitney</h3>
    </div>
    <div class="battle-labels">
        <span class="battle-label left-label">@LeftLabel</span>
        <span class="battle-score">@LeftScore — @RightScore</span>
        <span class="battle-label right-label">@RightLabel</span>
    </div>

    <div class="battle-bar-track">
        <div class="battle-bar-left" style="width: @(LeftPercent)%">
            <span class="battle-bar-pct">@LeftPercent%</span>
        </div>
        <div class="battle-divider"></div>
        <div class="battle-bar-right" style="width: @(RightPercent)%">
            <span class="battle-bar-pct">@RightPercent%</span>
        </div>
    </div>

    <div class="battle-buttons">
        <button class="battle-btn left-btn" @onclick="IncrementLeft">
            + @LeftLabel
        </button>
        <button class="battle-btn right-btn" @onclick="IncrementRight">
            + @RightLabel
        </button>
    </div>
</div>

@code {
    [Parameter] public string LeftLabel { get; set; } = "Nick";
    [Parameter] public string RightLabel { get; set; } = "Whitney";

    private int LeftScore = 1;
    private int RightScore = 1;

    private int Total => LeftScore + RightScore;
    private int LeftPercent => (int)Math.Round((double)LeftScore / Total * 100);
    private int RightPercent => 100 - LeftPercent;

    private void IncrementLeft() => LeftScore++;
    private void IncrementRight() => RightScore++;
}

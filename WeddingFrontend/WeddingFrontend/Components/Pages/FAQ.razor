@page "/faq"

<div class="faq-page">
    <h1 class="faq-title">FAQ</h1>
    <p class="faq-subtitle">Everything you need to know about the big day.</p>

    <div class="faq-list">
        @foreach (var item in Faqs)
        {
            <div class="faq-item @(item.IsOpen ? "open" : "")" @onclick="() => Toggle(item)">
                <div class="faq-question">
                    <span>@item.Question</span>
                    <span class="faq-arrow @(item.IsOpen ? "open" : "")"></span>
                </div>
                @if (item.IsOpen)
                {
                    <div class="faq-answer">
                        <p>@item.Answer</p>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<FaqItem> Faqs = new()
    {
        new FaqItem("Is There A Theme?", "img1 img2 img3"),
        new FaqItem("What's The Dress Code?", "Whatever makes you feel fancy. Please don't wear white."),
        new FaqItem("Is This An \"Unplugged\" Ceremony?","Nay. Feel free to take all the pictures. Delete bad ones & send the good ones to the bride at your earliest convenience."),
        new FaqItem("Can I Bring A +1?","This Is A Smaller Ceremony. Only those noted on the invitation are invited."),
        new FaqItem("What Time Should I Arrive?","Between 3:40PM - 4:00PM. Early birds will have to wait. Late comers can sneak in, but we'll all know."),
        new FaqItem("What's The Food & Drink Situation?","Appetizers & dinner will be served. The bar will be funded by us up to a point."),
        new FaqItem("Is This Going To Be Weird?","We hope so."),
        new FaqItem("What If I Become Part Of The Wedding?","This has already begun."),
        new FaqItem("Is There Going To Be Dancing?","No, but if you want to continue the party after dinner -- we've got a plan.")
    };

    private void Toggle(FaqItem item) => item.IsOpen = !item.IsOpen;

    private class FaqItem
    {
        public string Question { get; set; }
        public string Answer { get; set; }
        public bool IsOpen { get; set; } = false;

        public FaqItem(string question, string answer)
        {
            Question = question;
            Answer = answer;
        }
    }
}
